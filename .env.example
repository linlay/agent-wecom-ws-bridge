# 对方 gateway WSS 地址
GATEWAY_WS_URL=wss://gateway.example.com/ws/agent
GATEWAY_USER_ID=
GATEWAY_TICKET=
GATEWAY_AGENT_KEY=
GATEWAY_CHANNEL=wecom

# runner 地址（Docker 容器内用容器名，宿主机直接跑用 127.0.0.1）
# RUNNER_BASE_URL=http://127.0.0.1:11949
RUNNER_BASE_URL=http://agent-platform-runner:8080
RUNNER_BEARER_TOKEN=
DEFAULT_AGENT_KEY=default

# 健康检查端口
LISTEN_ADDR=:11970
