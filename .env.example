# Peer gateway WSS endpoint.
GATEWAY_WS_URL=wss://gateway.example.com/ws/agent
GATEWAY_USER_ID=
GATEWAY_TICKET=
GATEWAY_AGENT_KEY=
GATEWAY_CHANNEL=wecom

# Runner endpoint.
# For local host run you can use: http://127.0.0.1:11949
RUNNER_BASE_URL=http://agent-platform-runner:8080
RUNNER_BEARER_TOKEN=
DEFAULT_AGENT_KEY=default

# Optional gateway HTTP base URL override.
# If empty, bridge derives it from GATEWAY_WS_URL.
AGENT_GATEWAY_BASE_URL=
# Optional path prefix for relative upload URLs (object path style).
AGENT_GATEWAY_DOWNLOAD_PATH=/api/download
# Gateway upload endpoint used for artifact.publish forwarding.
AGENT_GATEWAY_UPLOAD_PATH=/api/upload

# Health check listen address.
LISTEN_ADDR=:11970
